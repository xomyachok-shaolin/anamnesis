[Unit]
Description=claude-mem-ext incremental sync
After=default.target

[Service]
Type=oneshot
WorkingDirectory=%h/projects/claude-mem-ext
Environment=PYTHONPATH=%h/projects/claude-mem-ext
ExecStart=%h/.claude-mem/semantic-env/bin/python -m mem_ext.cli sync
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

[Install]
WantedBy=default.target
