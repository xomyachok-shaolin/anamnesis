[Unit]
Description=claude-mem worker (web viewer on :37777 + MCP loopback)
After=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=%h
# Dynamic node (nvm) + bun path — resolved at service start so nvm upgrades
# don't require editing the unit.
ExecStart=/bin/bash -c 'nvm_bin=$(ls -d $HOME/.nvm/versions/node/v* 2>/dev/null | sort -V | tail -n1)/bin; export PATH="$HOME/.bun/bin:$nvm_bin:$HOME/.local/share/pnpm:/usr/local/bin:/usr/bin:/bin"; command -v npx >/dev/null || { echo "npx not found in PATH=$PATH"; exit 1; }; exec npx -y claude-mem start'
Restart=on-failure
RestartSec=10
StandardOutput=append:%h/.claude-mem/logs/worker-stdout.log
StandardError=append:%h/.claude-mem/logs/worker-stderr.log

# --- resource limits ---
MemoryMax=2G
CPUQuota=100%
TasksMax=256

# --- scheduling ---
Nice=5

# --- hardening ---
NoNewPrivileges=yes

[Install]
WantedBy=default.target
